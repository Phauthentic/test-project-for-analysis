<?xml version="1.0"?>
<ruleset name="analysis-test-project">
    <description>PSR-12 for fixture code; violations are intentional in some commits.</description>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>

    <arg name="colors"/>
    <arg value="ps"/>

    <rule ref="PSR12"/>
</ruleset>
